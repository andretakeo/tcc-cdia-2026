# Monorepo Global Environment Variables Template

# Database (Used by Prisma across packages)
DATABASE_URL="file:./packages/db/prisma/dev.db"

# OpenAI API Key (Required by apps/inference)
OPENAI_API_KEY="sk-..."

# Internal Service URLs
INFERENCE_API_URL="http://localhost:3001/api/analyze-raw"
DASHBOARD_URL="http://localhost:3000"
SCRAPER_URL="http://localhost:3002"
